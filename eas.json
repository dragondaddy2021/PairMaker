{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "credentialsSource": "remote",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "credentialsSource": "remote",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "enterpriseProvisioning": "universal"
      }
    },
    "hotfix": {
      "distribution": "internal",
      "channel": "hotfix",
      "credentialsSource": "remote",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./secrets/google-play-sa.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "REPLACE@example.com",
        "ascAppId": "REPLACE_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_TEAM_ID"
      }
    }
  }
}
