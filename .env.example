# ─── AWS ─────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_AWS_REGION=ap-northeast-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
EXPO_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_DYNAMODB_ENDPOINT=
EXPO_PUBLIC_S3_BUCKET=pairmaker-media
EXPO_PUBLIC_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com
EXPO_PUBLIC_API_STAGE=prod

# ─── Google Maps / Places ────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy_REPLACE_ME
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSy_REPLACE_ME

# ─── Claude AI ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-REPLACE_ME

# ─── Marketing / Deep Links ──────────────────────────────────────────────────
EXPO_PUBLIC_BRANCH_KEY=key_live_REPLACE_ME
EXPO_PUBLIC_FIREBASE_DYNAMIC_LINKS_PREFIX=https://pairmaker.page.link

# ─── CMS Backend ─────────────────────────────────────────────────────────────
CMS_PORT=4000
CMS_JWT_SECRET=REPLACE_ME_WITH_STRONG_SECRET
CMS_DB_PATH=./cms/data/db.json

# ─── CI / Slack ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME
SLACK_CHANNEL=#pairmaker-ci

# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=ci@your-org.com
JIRA_API_TOKEN=REPLACE_ME
JIRA_PROJECT_KEY=PM

# ─── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/gcp-sa.json

# ─── EAS ─────────────────────────────────────────────────────────────────────
EXPO_TOKEN=REPLACE_ME
