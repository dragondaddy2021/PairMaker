{
  "name": "temp_pairmaker",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:api": "vitest run --config tests/api/vitest.config.ts",
    "test:api:watch": "vitest --config tests/api/vitest.config.ts",
    "test:smoke": "wdio run tests/appium/wdio.conf.ts --spec 'tests/appium/smoke/*.test.ts'",
    "test:regression": "wdio run tests/appium/wdio.conf.ts --spec 'tests/appium/regression/*.test.ts'",
    "test:hotfix": "wdio run tests/appium/wdio.conf.ts --spec 'tests/appium/hotfix/*.test.ts'",
    "generate:icons": "node generate-icon.js",
    "release:notes": "ts-node scripts/release-note.ts",
    "notify:slack": "ts-node scripts/slack-notify.ts",
    "sync:sheets": "ts-node scripts/sheet-sync.ts",
    "jira:bug": "ts-node scripts/jira-bug.ts",
    "cms:dev": "cd cms/backend && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "^5.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "amazon-cognito-identity-js": "^6.3.12",
    "babel-preset-expo": "^55.0.17",
    "expo": "~54.0.33",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "^55.0.18",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "^55.1.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "^1.27.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "@types/xml2js": "^0.4.14",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "googleapis": "^140.0.0",
    "node-fetch": "^3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^2.0.0",
    "xml2js": "^0.6.2"
  },
  "private": true
}
